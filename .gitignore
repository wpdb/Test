# build output
dist/
.output/

# astro content collection cache & build artifacts
.astro/
.cache/
.turbo/

# dependencies
node_modules/

# logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# environment variables
.env
.env.production
.env.local
.jwt-public-key

# macOS-specific files
.DS_Store

# IDE
.vscode/
.idea/

# devcontainer (GitHub Codespaces)
.devcontainer/

# PhantomWP managed IDE tooling (auto-updated, regenerated on codespace boot)
# IMPORTANT: .phantomwp/runtime/ IS committed -- it ships with the production
# build. Only .phantomwp/ide/ (dev tools, codespace runtime) is ignored.
.phantomwp/ide/
.phantomwp/runtime/cache/

# Infrastructure version marker: runtime/environment state describing the
# version of the managed tooling above. Written by the scaffold, recreated on
# codespace boot, and rewritten by infra updates -- not source of truth, so it
# is not committed (keeps restore / branch-switch / pull from rolling it back).
.phantomwp-version

# Legacy locations from before infrastructure 1.24 (kept here so existing
# checkouts that still have these paths don't suddenly stage them on the
# first commit after pulling the migration).
.phantomwp/infra/
__phantom_dev_tools.mjs

# keepalive (prevents codespace shutdown)
.keepalive

# Sync manifest (incremental build cache, regenerated on each build)
src/lib/.sync-manifest.json

# component preview (generated by IDE)
public/_component-preview.html

# PhantomWP local Docker runtime
.docker-infra/
