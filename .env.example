# =============================================================================
# Environment Variables for Your Astro Site
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# .env is git-ignored on purpose. Never commit secrets to version control.
# For production, set these in your hosting platform's env-var UI
# (Vercel / Netlify / Cloudflare Pages / etc.).
# =============================================================================

# -----------------------------------------------------------------------------
# Site Configuration
# -----------------------------------------------------------------------------

# Your production site URL (used for sitemap, canonical URLs)
# SITE_URL=https://your-site.com

# -----------------------------------------------------------------------------
# WordPress Connection
# -----------------------------------------------------------------------------
# Your WordPress REST API URL is committed (it's safe -- it's just a URL) in
# src/lib/wordpress-config.ts. Your access secret is NOT committed -- it lives
# here in .env (and in your hosting platform's env-vars for production).
#
# Get the value from the PhantomWP WordPress Settings panel, or from the
# PhantomWP plugin's "Access Token" screen in your WordPress admin.
#
# Without this, any WordPress request that requires auth will fail with a 401.
WP_ACCESS_SECRET=

# WordPress framework: src/lib/wordpress.ts re-exports @phantomwp/wordpress
# which resolves to .phantomwp/runtime/lib/wordpress.ts (managed by PhantomWP).
# You only need to edit src/lib/wordpress-config.ts if you change the WP URL
# or the image-source mode.
