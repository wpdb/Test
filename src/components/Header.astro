---
import MainMenu from './menus/MainMenu.astro';
import BrandLogo from './BrandLogo.astro';

interface Props {
    class?: string;
}

const { class: className } = Astro.props;
---

<header class:list={["px-4 py-4", className]}>
    <div class="max-w-5xl mx-auto flex items-center justify-between">
        <BrandLogo siteName="My Site" class="font-semibold text-lg text-content no-underline cursor-pointer" />
        
        <!-- Menu Area (Right Aligned) -->
        <MainMenu />
    </div>
</header>
